{
    "version": 2,
    "builds": [
      { "src": "api/server.js", "use": "@vercel/node" },
      { "src": "frontend/package.json", "use": "@vercel/static-build" }
    ],
    "rewrites": [
      { "source": "/scrape/(.*)", "destination": "/api/server.js" },
      { "source": "/spotify/(.*)", "destination": "/api/server.js" }
    ]
  }